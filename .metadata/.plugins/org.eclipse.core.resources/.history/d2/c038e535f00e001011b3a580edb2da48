import java.util.*;

public class Star05 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("몇줄짜리 별을 만들까요?");
        int a= sc.nextInt();
        
        for(int i =1; i<=a; i++) {
        	for(int j=1; j<=i; j++) {
        		System.out.println(" ");
        	if(j==(a+1)*0.5) {
        		System.out.println();
        	}
        	}
        }
        
    }
}
