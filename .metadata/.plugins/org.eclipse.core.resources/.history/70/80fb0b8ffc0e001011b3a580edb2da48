import java.util.Scanner;

public class Hello {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("숫자 입력:");
        int n = sc.nextInt();
        
        if(n>=1&&n<=1000){
            if(n%2==0){
            System.out.print("n is even");
            }else{
            System.out.print("n is odd");
        }
    }
}
}