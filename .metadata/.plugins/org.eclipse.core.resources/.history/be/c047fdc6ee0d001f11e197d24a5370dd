import java.util.*;

public class HelloJava {
	public static void main(String[] args) {
//		 사용자로부터 양의 정수를 입력받아, 해당 숫자의 팩토리얼을 계산하여 출력하는 자바 프로그램을 작성해보세요.
//		 팩토리얼은 해당 숫자부터 1까지의 모든 양의 정수를 곱한 값입니다.
		Scanner sc = new Scanner(System.in);
		System.out.print("입력하라");
		int r=0;
		int a = sc.nextInt();
		for(int i=a; i==0; i-- ) {
			r+=i*r;
		}
		System.out.println(r);
		
		
	}

}
