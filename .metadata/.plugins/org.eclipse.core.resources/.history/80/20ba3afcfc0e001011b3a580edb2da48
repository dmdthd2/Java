import java.util.Scanner;

public class Hello {
    public static void main(String[] args) {
       Scanner sc= new Scanner(System.in);
       
       System.out.println("몇줄 사각형을 만들까");
       int a = sc.nextInt();
       
       for(int i=1; i<=a; i++) {
    	   if(i==1||i==a) {
			   for(int k =0; k<=i; k++) {
				   System.out.print("*");
			   }
		}else {
			if(i>1||i<a) {
				System.out.println(" ");
			}else {
				System.out.println("*");
			}
		}
    	   
       
       }
    
}
}