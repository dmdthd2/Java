import java.util.*;

public class Hello {

	public static void main(String[] args) {
		// TODO Auto-generated method stub

		
		Random rn = new Random();
		int n;
		
		for(int i=0; i<11; i++) {
			n=rn.nextInt(10)+1;
			System.out.print(n+": ");
			for(int j =0; j<n; j++) {
				System.out.print("*");
			}
		}
	}
}
