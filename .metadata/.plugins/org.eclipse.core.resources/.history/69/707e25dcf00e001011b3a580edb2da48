import java.util.*;

public class Star05 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("몇줄짜리 별을 만들까요?");
        int a= sc.nextInt();
        
        for(int i =1; i<=a; i++) {
        		
        	 if (i==(a+1)/2) {
        		System.out.print("*");
        	}else {
        		System.out.print(" ");
        	}
        	}
        
        
    }
}
