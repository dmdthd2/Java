import java.util.*;

public class HelloJava {
	public static void main(String[] args) {
		//사용자로부터 정수 N을 입력받아, 1부터 N까지의 모든 정수의 합을 계산하여 출력하는 자바 프로그램을 작성해보세요
		Scanner sc = new Scanner(System.in);
		System.out.print("입력하라");
		int reslut=0;
		int a = sc.nextInt();
		for(int i=1; i<a; i++ ) {
			reslut+=i;
		}
		System.out.println(a+"까지 수의 합은"+reslut);
		
		
	}

}
