import java.util.*;

public class HelloJava {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.println("몇의 약수의 합을 알고싶은가?");
		int a = sc.nextInt();
		int sum=0;
		for(int i = 1; i<=a; i++) {
			if(a%i==0) {
				sum+=i;
			}
		}
		System.out.println(sum);
	}

}
