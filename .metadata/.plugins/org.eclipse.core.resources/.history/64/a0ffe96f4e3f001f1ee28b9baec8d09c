import java.util.*;

public class HelloJava {
	public static void main(String[] args) {
//		배열의 최대값과 최소값 찾기
//		사용자로부터 배열의 크기와 배열의 요소들을 입력받아, 배열 내의 최대값과 최소값을 찾아 출력하는 프로그램을 작성하세요.
		Scanner sc1 = new Scanner(System.in);
		Scanner sc2 = new Scanner(System.in);
		System.out.println("배열의 크기를 입력하세요.");
		int a = sc1.nextInt();
		int[] ar = new int[a];
		System.out.println("배열의 요소를 입력하세요");
		for(int i=0; i<a; i++) {
		ar[i]=sc2.nextInt();
		}
		int max=ar[0];
		int min= ar[0];
		
		for(int i = 0; i<a; i++) {
			if(max<ar[i]) {
				max=ar[i];
			}
		}
		for(int i = 0; i<a; i++) {
			if(min>ar[i]) {
				min+=ar[i];
			}
		}
		System.out.println("배열 내의 최댓값은 "+max+"이고 최솟값은 "+min+" 입니다");

		

		
		
		
		}
	}

